-- Optimization and Completion of Mod Menu GUI Script

-- Function to create a toggle with proper circleCorner variable
def CreateToggle(name, position, defaultState)
    local toggle = Circle.new(position, circleCorner)
    toggle:setState(defaultState)
    return toggle
end

-- Function to create sliders for numerical inputs
function CreateSlider(name, position, minValue, maxValue, defaultValue)
    local slider = Slider.new(name, position, minValue, maxValue)
    slider:setValue(defaultValue)
    return slider
end

-- Function to create buttons for actions
function CreateButton(name, position, action)
    local button = Button.new(name, position)
    button:onClick(action)
    return button
end

-- Memory management system
local connections = {}

function trackConnection(conn)
    table.insert(connections, conn)
end

function cleanupConnections()
    for _, conn in ipairs(connections) do
        conn:disconnect()
    end
    connections = {}
end

-- Optimized GetClosestPlayer function with caching
local playerCache = {}

function GetClosestPlayer()
    local closestPlayer = nil
    local closestDistance = math.huge
    for _, player in pairs(game.Players:GetPlayers()) do
        if player ~= localPlayer then
            local distance = (player.Position - localPlayer.Position).magnitude
            if distance < closestDistance then
                closestDistance = distance
                closestPlayer = player
            end
        end
    end
    playerCache[localPlayer] = closestPlayer
    return closestPlayer
end

-- Aimbot implementation with smooth targeting
function Aimbot()
    local closestPlayer = GetClosestPlayer()
    if closestPlayer then
        local targetPosition = closestPlayer:GetPosition()
        local smoother = Smooth.new()
        local newPosition = smoother:interpolate(localPlayer.Position, targetPosition)
        localPlayer:setPosition(newPosition)
    end
end

-- ESP implementation with box, tracer and name display
function SetupESP(player)
    local box = Box.new(player.Position)
    local tracer = Tracer.new(localPlayer.Position, player.Position)
    local nameTag = NameDisplay.new(player.Name, player.Position)
    trackConnection(box)  
    trackConnection(tracer)
    trackConnection(nameTag)
end

-- Walkspeed modifier
function SetWalkspeed(speed)
    localPlayer.WalkSpeed = speed
end

-- Error handling with pcall throughout
function safeCall(func)
    local success, err = pcall(func)
    if not success then
        warn("Error occurred: " .. err)
    end
    return success
end

-- Cleanup connections on menu close
function OnMenuClose()
    cleanupConnections()
end

-- Add event connection cleanup on menu close
trackConnection(game:GetService('UserInputService').InputEnded:Connect(OnMenuClose))