local function Tween(obj, props, duration, style, dir, callback)
    style = style or Enum.EasingStyle.Quart
    dir = dir or Enum.EasingDirection.Out
    local tween = TweenService:Create(obj, TweenInfo.new(duration or 0.3, style, dir), props)
    tween:Play()
    if callback then
        tween.Completed:Connect(callback)
    end
    return tween
end

local function IsMobile()
    return UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled
end

local function GetClosestPlayer(maxDist, useFOV, fovRadius)
    maxDist = maxDist or 1000
    local closest = nil
    local minDist = maxDist
    local screenCenter = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local humanoid = player.Character:FindFirstChild("Humanoid")
            if humanoid and humanoid.Health > 0 then
                local pos, onScreen = Camera:WorldToViewportPoint(player.Character.HumanoidRootPart.Position)
                if onScreen then
                    local dist = (Vector2.new(pos.X, pos.Y) - screenCenter).Magnitude
                    local worldDist = (player.Character.HumanoidRootPart.Position - Camera.CFrame.Position).Magnitude
                    
                    if useFOV then
                        if dist <= fovRadius and worldDist < minDist then
                            minDist = worldDist
                            closest = player
                        end
                    else
                        if worldDist < minDist then
                            minDist = worldDist
                            closest = player
                        end
                    end
                end
            end
        end
    end
    return closest
end

