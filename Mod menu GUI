    msgLabel.TextSize = 12
    msgLabel.Font = Enum.Font.Gotham
    msgLabel.TextXAlignment = Enum.TextXAlignment.Left
    msgLabel.TextWrapped = true
    msgLabel.Parent = notif
    
    notif.Parent = NotificationContainer
    
    -- Animate in
    Tween(notif, {Size = UDim2.new(0, 280, 0, 70)}, 0.4, Enum.EasingStyle.Back)
    
    -- Auto remove
    task.delay(duration, function()
        Tween(notif, {Size = UDim2.new(0, 0, 0, 70), Position = UDim2.new(0, 50, notif.Position.Y.Scale, notif.Position.Y.Offset)}, 0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In, function()
            notif:Destroy()
        end)
    end)
end

