local function CreateTabButton(name, icon, page)
    local btn = Instance.new("TextButton")
    btn.Name = name .. "Btn"
    btn.Size = UDim2.new(1, 0, 0, 45)
    btn.BackgroundColor3 = name == "Home" and Color3.fromRGB(138, 43, 226) or Color3.fromRGB(40, 40, 60)
    btn.Text = icon .. " " .. name
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.TextSize = 14
    btn.Font = Enum.Font.GothamSemibold
    btn.AutoButtonColor = false
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 10)
    corner.Parent = btn
    
    local stroke = Instance.new("UIStroke")
    stroke.Color = name == "Home" and Color3.fromRGB(0, 255, 255) or Color3.fromRGB(60, 60, 80)
    stroke.Thickness = 2
    stroke.Parent = btn
    
    -- Hover effects
    btn.MouseEnter:Connect(function()
        if getgenv().ModMenu.CurrentTab ~= name then
            Tween(btn, {BackgroundColor3 = Color3.fromRGB(60, 60, 90)}, 0.2)
        end
    end)
    
    btn.MouseLeave:Connect(function()
        if getgenv().ModMenu.CurrentTab ~= name then
            Tween(btn, {BackgroundColor3 = Color3.fromRGB(40, 40, 60)}, 0.2)
        end
    end)
    
    -- Click handler
    btn.MouseButton1Click:Connect(function()
        if getgenv().ModMenu.CurrentTab == name then return end
        
        -- Update previous button
        for _, child in ipairs(Sidebar:GetChildren()) do
            if child:IsA("TextButton") then
                Tween(child, {BackgroundColor3 = Color3.fromRGB(40, 40, 60)}, 0.2)
                child:FindFirstChildOfClass("UIStroke").Color = Color3.fromRGB(60, 60, 80)
            end
        end
        
        -- Highlight current
        Tween(btn, {BackgroundColor3 = Color3.fromRGB(138, 43, 226)}, 0.2)
        stroke.Color = Color3.fromRGB(0, 255, 255)
        
        getgenv().ModMenu.CurrentTab = name
        
        -- Page transition
        for pageName, pageFrame in pairs(Pages) do
            if pageName == name then
                pageFrame.Visible = true
                pageFrame.Position = UDim2.new(0.05, 0, 0, 0)
                pageFrame.BackgroundTransparency = 1
                Tween(pageFrame, {Position = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 0}, 0.3)
            else
                Tween(pageFrame, {Position = UDim2.new(-0.05, 0, 0, 0)}, 0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In, function()
                    pageFrame.Visible = false
                end)
            end
        end
    end)
    
    btn.Parent = Sidebar
    return btn
end

